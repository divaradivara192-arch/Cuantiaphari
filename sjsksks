<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cuan WhatsApp</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #020617;
  color: white;
  text-align: center;
  overflow: hidden;
}

/* Background glow */
body::before {
  content: "";
  position: fixed;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at top, #001a00, #000);
  z-index: -1;
}

/* Judul */
h1 {
  margin-top: 40px;
  font-size: 32px;
  font-weight: bold;
}

/* Subtext */
.sub {
  color: #9ca3af;
  margin-top: 10px;
}

/* Waktu */
.time {
  color: #00ff88;
  margin-top: 10px;
  font-size: 14px;
}

/* Container */
.container {
  padding: 20px;
}

/* Button besar */
.btn {
  display: block;
  margin: 15px auto;
  padding: 18px;
  width: 90%;
  max-width: 400px;
  border-radius: 15px;
  background: #1e293b;
  color: white;
  font-size: 18px;
  font-weight: bold;
  text-decoration: none;
  box-shadow: 0 0 20px rgba(0,255,136,0.5);
  border: 1px solid #00ff88;
  transition: 0.3s;
}

.btn:hover {
  transform: scale(1.03);
  box-shadow: 0 0 30px #00ff88;
}

/* Box keuntungan */
.box {
  margin: 20px auto;
  padding: 20px;
  width: 90%;
  max-width: 400px;
  border-radius: 15px;
  border: 2px solid #00ff88;
  background: #020617;
  box-shadow: 0 0 20px #00ff88;
  text-align: left;
}

.box h2 {
  text-align: center;
  color: #00ff88;
}

.box p {
  margin: 8px 0;
}

/* Uang jatuh */
.money {
  position: absolute;
  top: -50px;
  font-size: 20px;
  animation: fall linear infinite;
}

@keyframes fall {
  to { transform: translateY(110vh); }
}

</style>
</head>
<body>

<div class="container">

  <h1>Cuan dari WhatsApp</h1>

  <div class="sub">Cara mudah hasilkan uang hanya dari chat!</div>

  <div class="time" id="jam">
    ⏱ WIB: -- | WITA: -- | WIT: --
  </div>

  <a href="https://gabungwa.com/signup?ref=71847" class="btn">🚀 Daftar</a>
  <a href="https://gabungwa.com/signup?ref=71847" class="btn">🔥 Daftar</a>
  <a href="https://whatsapp.com/channel/0029VbC1MHP1t90bIcMBrQ14" class="btn">📢 Join Channel</a>

  <div class="box">
    <h2>🔥 KEUNTUNGAN 🔥</h2>
    <p>✔ Bisa open sewa WA</p>
    <p>✔ Tanpa syarat apapun</p>
    <p>✔ WD 24 jam non-stop</p>
    <p>✔ WD super cepat gak sampai 5 menit</p>
  </div>

</div>

<script>
// JAM REALTIME
function updateJam() {
  const now = new Date();

  const WIB = new Date(now.getTime());
  const WITA = new Date(now.getTime() + 60*60*1000);
  const WIT = new Date(now.getTime() + 2*60*60*1000);

  document.getElementById("jam").innerHTML =
    "⏱ WIB: " + WIB.toLocaleTimeString() +
    " | WITA: " + WITA.toLocaleTimeString() +
    " | WIT: " + WIT.toLocaleTimeString();
}
setInterval(updateJam, 1000);

// uang jatuh
function createMoney() {
  const money = document.createElement("div");
  money.classList.add("money");
  money.innerText = "💸";

  money.style.left = Math.random() * 100 + "vw";
  money.style.animationDuration = (Math.random() * 3 + 2) + "s";

  document.body.appendChild(money);
  setTimeout(() => money.remove(), 5000);
}
setInterval(createMoney, 200);
</script>

</body>
</html>
